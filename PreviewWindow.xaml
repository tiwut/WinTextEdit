<Window x:Class="WinTextEdit.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Preview - WinTextEdit" 
        Icon="app.ico"
        Height="550" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackground}"
        Foreground="{DynamicResource ThemeForeground}">
    
    <Window.Resources>
        <Style x:Key="HeaderComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="{DynamicResource ThemeMenuBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeMenuBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Width" Value="150"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{DynamicResource ThemeMenuBackground}" 
                BorderBrush="{DynamicResource ThemeMenuBorder}" 
                BorderThickness="0,0,0,1" 
                Padding="15,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Preview Mode:" 
                           FontWeight="SemiBold" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           Foreground="{DynamicResource ThemeForeground}"/>
                
                <ComboBox Name="PreviewModeComboBox" 
                          Style="{StaticResource HeaderComboBox}"
                          SelectionChanged="PreviewModeComboBox_SelectionChanged">
                    <ComboBoxItem Content="HTML"/>
                    <ComboBoxItem Content="Markdown"/>
                    <ComboBoxItem Content="CSS"/>
                    <ComboBoxItem Content="Raw Code"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <WebBrowser Name="PreviewBrowser" Margin="0"/>
        </Grid>
    </Grid>
</Window>
