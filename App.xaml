<Application x:Class="WinTextEdit.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WinTextEdit"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="ThemeBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ThemeForeground" Color="#000000" />
        <SolidColorBrush x:Key="ThemeMenuBackground" Color="#F5F5F5" />
        <SolidColorBrush x:Key="ThemeMenuForeground" Color="#000000" />
        <SolidColorBrush x:Key="ThemeMenuBorder" Color="#E0E0E0" />
        <SolidColorBrush x:Key="ThemeStatusBarBackground" Color="#007ACC" />
        <SolidColorBrush x:Key="ThemeStatusBarForeground" Color="#FFFFFF" />
    </Application.Resources>
</Application>
